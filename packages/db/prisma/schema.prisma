// Prisma Schema for DreamForge AI Platform
// SQLite (开发) / PostgreSQL 14+ (生产)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ 用户与鉴权 ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          String    @default("USER")
  credits       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  apiKeys       ApiKey[]
  providers     UserProvider[]
  tasks         Task[]
  assets        Asset[]
  workflows     Workflow[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Session {
  id           String   @id
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  keyHash     String   @unique
  prefix      String
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ============ 提供商配置 ============

model UserProvider {
  id             String   @id @default(cuid())
  userId         String
  providerId     String
  name           String
  baseUrl        String
  protocol       String   @default("openai")
  enabled        Boolean  @default(true)
  isPrimary      Boolean  @default(false)
  llmModels      String   @default("[]")
  imageModels    String   @default("[]")
  videoModels    String   @default("[]")
  capabilities   String   @default("{}")
  rateLimitRpm   Int      @default(60)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey         ProviderApiKey?

  @@unique([userId, providerId])
  @@map("user_providers")
}

model ProviderApiKey {
  id             String       @id @default(cuid())
  userProviderId String       @unique
  encryptedKey   String
  createdAt      DateTime     @default(now())

  userProvider   UserProvider @relation(fields: [userProviderId], references: [id], onDelete: Cascade)

  @@map("provider_api_keys")
}

// ============ 任务系统 ============

model Task {
  id             String        @id @default(cuid())
  userId         String
  provider       String
  model          String
  modality       String        @default("image")
  status         String        @default("created")
  input          String        @default("{}")
  output         String?
  creditsCost    Int           @default(0)
  startedAt      DateTime?
  finishedAt     DateTime?
  errorCode      String?
  errorMessage   String?
  retryable      Boolean?
  retryCount     Int           @default(0)
  parentTaskId   String?
  workflowNodeId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets         Asset[]

  @@map("tasks")
}

// ============ 资产系统 ============

model Asset {
  id            String     @id @default(cuid())
  userId        String
  type          String     @default("image")
  url           String
  thumbnail     String?
  parentId      String?
  taskId        String
  provider      String
  model         String
  prompt        String     @default("")
  params        String     @default("{}")
  seed          Int?
  creditsCost   Int        @default(0)
  rootAssetId   String?
  version       Int        @default(1)
  tags          String     @default("[]")
  isPublic      Boolean    @default(false)
  createdAt     DateTime   @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("assets")
}

// ============ 工作流系统 ============

model Workflow {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  definition  String        @default("{}")
  isTemplate  Boolean       @default(false)
  isPublic    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]

  @@map("workflows")
}

model WorkflowExecution {
  id          String     @id @default(cuid())
  workflowId  String
  userId      String
  status      String     @default("created")
  input       String     @default("{}")
  output      String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime   @default(now())

  workflow    Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_executions")
}

// ============ 计费系统 ============

model CreditTransaction {
  id          String              @id @default(cuid())
  userId      String
  amount      Int
  type        String              @default("usage")
  description String?
  taskId      String?
  createdAt   DateTime            @default(now())

  @@map("credit_transactions")
}

model ModelPricing {
  id           String       @id @default(cuid())
  provider     String
  model        String
  modality     String       @default("image")
  pricingType  String       @default("fixed")
  unitCost     Int          @default(0)
  tiers        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([provider, model])
  @@map("model_pricings")
}

// ============ 审计日志 ============

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  metadata  String   @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ============ 内容审核 ============

model ContentModeration {
  id          String                @id @default(cuid())
  assetId     String                @unique
  status      String                @default("pending")
  flagged     Boolean               @default(false)
  categories  String                @default("[]")
  confidence  Float?
  metadata    String                @default("{}")
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime              @default(now())

  @@map("content_moderations")
}
