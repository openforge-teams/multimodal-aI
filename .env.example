# ============ 数据库 ============
DATABASE_URL=postgresql://dreamforge:dreamforge@localhost:5432/dreamforge

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ S3 存储 (MinIO / AWS S3 / Cloudflare R2) ============
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=dreamforge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ============ 鉴权 ============
BETTER_AUTH_SECRET=change-this-to-a-long-random-string-in-production

# OAuth - GitHub
OAUTH_GITHUB_ID=
OAUTH_GITHUB_SECRET=

# OAuth - Google
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=

# ============ 默认提供商（系统级，可选） ============
# 默认 LLM Provider
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_LIST=-all,+gpt-4o,+gpt-4o-mini

# 默认图像 Provider
DEFAULT_IMAGE_PROVIDER=
# 默认视频 Provider
DEFAULT_VIDEO_PROVIDER=

# ============ 任务配置 ============
TASK_MAX_CONCURRENCY=10
TASK_POLL_INTERVAL=5000
TASK_TIMEOUT=600000

# ============ 计费 ============
CREDITS_FREE_TIER=1000

# ============ Node.js ============
NODE_ENV=development
